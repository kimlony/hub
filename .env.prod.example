SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=3000

POSTGRES_DB=hub_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=hub_db
POSTGRES_USER=hub
POSTGRES_PASSWORD=replace-with-prod-db-password
POSTGRES_URL=jdbc:postgresql://postgres:5432/hub_db

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BROKERS=kafka:9092
HUB_KAFKA_TOPICS_JOBS=hub.jobs
KAFKA_TOPIC=hub.jobs
HUB_JOBS_DLQ_TOPIC=hub.jobs.dlq
KAFKA_DLQ_TOPIC=hub.jobs.dlq
KAFKA_GROUP_ID=hub-worker-group
KAFKA_CLIENT_ID=hub-worker
KAFKA_NUM_PARTITIONS=4

HUB_SECURITY_ENABLED=true
HUB_API_KEY=replace-with-prod-api-key
HUB_JWT_SECRET=replace-with-prod-jwt-secret
HUB_AES_SECRET=replace-with-32-byte-prod-secret

NODE_ENV=production
LOG_LEVEL=info
WORKER_HTTP_PORT=4000
JOB_LOCK_TTL_MINUTES=30
JOB_RETRY_BACKOFF_MS=60000,300000,900000
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
GRACEFUL_SHUTDOWN_TIMEOUT_MS=60000

GODO_BASE_URL=http://openhub.godo.co.kr/godomall5
GODO_PAGE_SIZE=100
GCHAN_BASE_URL=https://example.invalid/gchan
WCHAN_BASE_URL=https://scm.buyis.co.kr
ONRY_BASE_URL=https://api.onnurichance.com
