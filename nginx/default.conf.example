server {
    listen 80;
    server_name hub.rony.kr;

    # Serve only the ACME challenge over HTTP; all other traffic uses HTTPS.
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name hub.rony.kr;

    ssl_certificate /etc/letsencrypt/live/hub.rony.kr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hub.rony.kr/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Docker DNS must be resolved again when the hub-api container is recreated.
    resolver 127.0.0.11 valid=10s ipv6=off;

    client_max_body_size 10m;

    location / {
        set $hub_api_upstream http://hub-api:3000;
        proxy_pass $hub_api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
