SERVER_PORT=3000

POSTGRES_URL=jdbc:postgresql://localhost:5432/hub_db
POSTGRES_USER=hub
POSTGRES_PASSWORD=change-me

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
HUB_JOBS_TOPIC=hub.jobs
HUB_JOBS_TOPIC_PARTITIONS=4
HUB_JOBS_TOPIC_REPLICAS=1

HUB_SECURITY_ENABLED=true
HUB_API_KEY_HEADER=X-Hub-Api-Key
HUB_API_KEY=change-me-local-api-key

HUB_JWT_SECRET=change-me-jwt-secret-local-256bits
HUB_JWT_EXPIRY_MS=86400000

# Must be exactly 32 bytess
HUB_AES_SECRET=change-me-32-byte-secret-local!!
