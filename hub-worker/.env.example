PORT=3000
LOG_LEVEL=info
JOB_LOCK_TTL_MINUTES=30
JOB_LEASE_MINUTES=30
JOB_RETRY_BACKOFF_MS=60000,300000,900000
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
GRACEFUL_SHUTDOWN_TIMEOUT_MS=60000
TEST_SLEEP_MAX_MS=300000

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=hub_db
POSTGRES_USER=hub
POSTGRES_PASSWORD=change-me

# Must be exactly 32 bytes and must match hub-api-erp.
HUB_AES_SECRET=change-me-32-byte-secret-local!!

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=hub.jobs
KAFKA_DLQ_TOPIC=hub.jobs.dlq
KAFKA_GROUP_ID=hub-worker-group
KAFKA_CLIENT_ID=hub-worker

# Optional local-only override for 11st API testing.
ELEVENST_API_KEY_OVERRIDE=

# Optional GODO API settings.
GODO_BASE_URL=http://openhub.godo.co.kr/godomall5
GODO_PAGE_SIZE=100

# Optional GCHAN API settings. Use a real endpoint only in local/private env files.
GCHAN_BASE_URL=https://example.invalid/gchan

# WCHAN (Welfare Chance) session-cookie API. Use scm.buyis.co.kr for production.
WCHAN_BASE_URL=https://scmdev.buyis.co.kr

# ONRY channel. Channel account auth_key takes precedence over this fallback.
# The access token is issued at login and is not stored.
ONRY_BASE_URL=https://api.onnurichance.com
ONRY_X_API_KEY=

# DART disclosure crawler.
DART_API_KEY=

# Optional Naver RSS crawler settings.
NAVER_RSS_URLS=https://www.yna.co.kr/rss/economy.xml,https://www.hankyung.com/feed/economy
