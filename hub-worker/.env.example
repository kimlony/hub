PORT=3000
LOG_LEVEL=info
JOB_LOCK_TTL_MINUTES=30

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=hub_db
POSTGRES_USER=hub
POSTGRES_PASSWORD=change-me

# Must be exactly 32 bytes and must match hub-api-erp.
HUB_AES_SECRET=change-me-32-byte-secret-local!!

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=hub.jobs
KAFKA_GROUP_ID=hub-worker-group
KAFKA_CLIENT_ID=hub-worker

# Oracle
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=ORCLCDB
ORACLE_USER=hub
ORACLE_PASSWORD=change-me

# Optional local-only override for 11st API testing.
ELEVENST_API_KEY_OVERRIDE=
