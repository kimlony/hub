{
  "name": "hub-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Kafka worker for HUB job processing",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:consumer": "pm2 start ecosystem.config.cjs --only hub-worker-consumer",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "kafkajs": "^2.2.4",
    "oracledb": "^6.7.2",
    "pg": "^8.13.1",
    "pino": "^9.9.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/oracledb": "^6.10.3",
    "@types/pg": "^8.11.10",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
